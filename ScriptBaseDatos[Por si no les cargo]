-- 1. TABLAS DE DOMINIO
CREATE TABLE Dominio_Estado (
    id_estado SERIAL PRIMARY KEY,
    nombre VARCHAR(20) NOT NULL
);

CREATE TABLE Dominio_Genero (
    id_genero SERIAL PRIMARY KEY,
    nombre VARCHAR(20) NOT NULL
);

CREATE TABLE Dominio_Especialidad (
    id_especialidad SERIAL PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL
);

CREATE TABLE Dominio_EstadoCita (
    id_estado_cita SERIAL PRIMARY KEY,
    nombre VARCHAR(30) NOT NULL
);

-- 2. SEGURIDAD Y USUARIOS
CREATE TABLE Usuario (
    id_usuario SERIAL PRIMARY KEY,
    usuario VARCHAR(50) UNIQUE NOT NULL,
    contrasena TEXT NOT NULL
);

CREATE TABLE Rol (
    id_rol SERIAL PRIMARY KEY,
    nombre VARCHAR(30) NOT NULL,
    id_usuario INT NOT NULL,
    CONSTRAINT fk_rol_usuario FOREIGN KEY (id_usuario) REFERENCES Usuario(id_usuario) ON DELETE CASCADE
);

CREATE TABLE Sesion_Token (
    id_token SERIAL PRIMARY KEY,
    token_hash TEXT NOT NULL,
    fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    fecha_expiracion TIMESTAMP NOT NULL,
    id_estado INT REFERENCES Dominio_Estado(id_estado),
    id_usuario INT NOT NULL,
    CONSTRAINT fk_token_usuario FOREIGN KEY (id_usuario) REFERENCES Usuario(id_usuario) ON DELETE CASCADE
);

-- 3. PERSONAS Y ESPECIALIZACIONES
CREATE TABLE Persona (
    id_persona SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    cedula_ciudadania VARCHAR(20) UNIQUE NOT NULL,
    apellido VARCHAR(100) NOT NULL,
    celular VARCHAR(15),
    id_genero INT REFERENCES Dominio_Genero(id_genero),
    fecha_nacimiento DATE,
    correo VARCHAR(100),
    id_usuario INT UNIQUE REFERENCES Usuario(id_usuario),
    id_estado INT REFERENCES Dominio_Estado(id_estado)
);

CREATE TABLE Medico_Terapista (
    id_persona INT PRIMARY KEY REFERENCES Persona(id_persona) ON DELETE CASCADE,
    id_especialidad INT REFERENCES Dominio_Especialidad(id_especialidad)
);

CREATE TABLE Agendador (
    id_persona INT PRIMARY KEY REFERENCES Persona(id_persona) ON DELETE CASCADE
);

CREATE TABLE Paciente (
    id_persona INT PRIMARY KEY REFERENCES Persona(id_persona) ON DELETE CASCADE,
);

-- 4. OPERATIVA
CREATE TABLE Jornada_Laboral (
    id_jornada SERIAL PRIMARY KEY,
    id_medico INT NOT NULL,
    hora_inicio TIME NOT NULL,
    hora_fin TIME NOT NULL,
    dias_semana VARCHAR(50),
    duracion_estimada_atencion INT,
    CONSTRAINT fk_jornada_medico FOREIGN KEY (id_medico) REFERENCES Medico_Terapista(id_persona) ON DELETE CASCADE
);

CREATE TABLE Cita (
    id_cita SERIAL PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES Paciente(id_persona),
    id_medico INT NOT NULL REFERENCES Medico_Terapista(id_persona),
    fecha DATE NOT NULL,
    hora_inicio TIME NOT NULL,
    hora_fin TIME NOT NULL,
    id_estado_cita INT REFERENCES Dominio_EstadoCita(id_estado_cita)
);