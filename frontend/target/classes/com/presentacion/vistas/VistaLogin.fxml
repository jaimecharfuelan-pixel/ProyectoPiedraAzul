<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.proyecto.presentacion.controladores.ControladorLogin"
           stylesheets="@../Estilos/estilos.css">
   <children>

      <!-- ===== PANTALLA PRINCIPAL LOGIN ===== -->
      <HBox fx:id="panelLogin"
            maxWidth="Infinity" maxHeight="Infinity"
            alignment="CENTER" spacing="20"
            style="-fx-padding: 40;">

         <!-- Panel izquierdo: formulario -->
         <VBox alignment="CENTER"
               styleClass="logo-card"
               prefWidth="420" minWidth="380" maxWidth="420"
               style="-fx-padding: 48 40 40 40;">
            <children>
               <Label styleClass="info-title" text="Bienvenido"
                      style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-padding: 0 0 8 0;"/>
               <Label styleClass="label-grey-small"
                      text="Por favor ingrese sus credenciales para acceder al portal."
                      wrapText="true"
                      style="-fx-font-size: 15px; -fx-padding: 0 0 28 0;"/>

               <Label text="Usuario"
                      style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 0 0 6 0;"/>
               <TextField fx:id="txtUsuario"
                          prefHeight="46" maxWidth="Infinity"
                          promptText="Usuario123"
                          styleClass="text-field"/>
               <Label fx:id="lblErrorUsuario" maxWidth="Infinity"
                      style="-fx-text-fill: #e53935; -fx-font-size: 12px; -fx-padding: 2 0 0 0;"/>

               <Label text="Contraseña"
                      style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 14 0 6 0;"/>
               <PasswordField fx:id="txtContrasena"
                              prefHeight="46" maxWidth="Infinity"
                              promptText="••••••••"
                              styleClass="password-field"/>

               <HBox alignment="CENTER_RIGHT" style="-fx-padding: 6 0 16 0;">
                  <Hyperlink text="¿Olvidó su contraseña?" style="-fx-font-size: 13px;"/>
               </HBox>

               <!-- Notificación inline (oculta por defecto) -->
               <HBox fx:id="boxNotificacion"
                     visible="false" managed="false"
                     maxWidth="Infinity" spacing="10"
                     alignment="CENTER_LEFT"
                     style="-fx-padding: 12 16 12 16; -fx-background-radius: 10;
                            -fx-background-color: #fdecea; -fx-border-color: #e53935;
                            -fx-border-radius: 10; -fx-border-width: 1.5;">
                  <Label text="⚠" style="-fx-font-size: 18px; -fx-text-fill: #e53935;"/>
                  <VBox spacing="2" HBox.hgrow="ALWAYS">
                     <Label fx:id="lblNotiTitulo"
                            style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #b71c1c;"/>
                     <Label fx:id="lblNotiMensaje"
                            wrapText="true" maxWidth="Infinity"
                            style="-fx-font-size: 12px; -fx-text-fill: #c62828;"/>
                  </VBox>
                  <Button fx:id="btnCerrarNoti"
                          onAction="#onCerrarNotificacion" text="✕"
                          style="-fx-background-color: transparent; -fx-text-fill: #e53935;
                                 -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 0 4 0 4;"/>
               </HBox>

               <Button fx:id="btnLogin"
                       onAction="#onBtnIniciarSesionClicked"
                       prefHeight="48" maxWidth="Infinity"
                       text="INICIAR SESIÓN"
                       style="-fx-font-size: 16px; -fx-padding: 0;"/>

               <HBox alignment="CENTER" spacing="4" style="-fx-padding: 18 0 0 0;">
                  <Label styleClass="label-grey-small"
                         text="¿No tienes una cuenta?" style="-fx-font-size: 14px;"/>
                  <Hyperlink text="Regístrese aquí" style="-fx-font-size: 14px;"/>
               </HBox>
            </children>
         </VBox>

         <!-- Panel derecho: info + logo -->
         <VBox alignment="CENTER" spacing="20"
               styleClass="login-right-pane"
               prefWidth="420" minWidth="380" maxWidth="420"
               style="-fx-padding: 48 40 40 40;">
            <children>
               <VBox styleClass="logo-card" alignment="CENTER"
                     style="-fx-padding: 24 20 24 20;">
                  <ImageView fitHeight="110" fitWidth="240"
                             pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png"/>
                     </image>
                  </ImageView>
               </VBox>
               <Label styleClass="info-title"
                      text="Salud y Bienestar a su Alcance"
                      wrapText="true" maxWidth="Infinity"
                      style="-fx-font-size: 22px; -fx-font-weight: bold;
                             -fx-text-alignment: center; -fx-alignment: center;"/>
               <Label styleClass="info-text"
                      text="Gestione sus citas médicas de manera rápida y segura. Acceda a su historial y reserve especialistas."
                      textAlignment="CENTER" wrapText="true" maxWidth="Infinity"
                      style="-fx-font-size: 15px; -fx-text-fill: #555555; -fx-alignment: center;"/>
            </children>
         </VBox>
      </HBox>

      <!-- ===== POPUP: CREAR CUENTA ===== -->
      <VBox fx:id="popupCrearCuenta"
            styleClass="ventana-popup"
            maxWidth="440" maxHeight="580"
            visible="false"
            style="-fx-padding: 24;">
         <children>
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
               <Label styleClass="titulo-popup" text="Crear Cuenta"
                      HBox.hgrow="ALWAYS"
                      style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
               <Button fx:id="btnLogin1"
                       onAction="#onBtnIniciarSesionClicked"
                       styleClass="btn-cerrar" text="✕"/>
            </HBox>
            <ScrollPane fitToWidth="true" prefHeight="440"
                        style="-fx-background-color: transparent; -fx-padding: 0;">
               <content>
                  <VBox spacing="10" style="-fx-padding: 4 8 4 4;">
                     <Label text="Nombre de Usuario *" style="-fx-font-weight: bold;"/>
                     <TextField promptText="Nombre de usuario" prefHeight="40" maxWidth="Infinity"/>
                     <Label text="Contraseña *" style="-fx-font-weight: bold;"/>
                     <TextField promptText="Contraseña" prefHeight="40" maxWidth="Infinity"/>
                     <Label text="Nombre *" style="-fx-font-weight: bold;"/>
                     <TextField promptText="Nombre" prefHeight="40" maxWidth="Infinity"/>
                     <Label text="Apellido *" style="-fx-font-weight: bold;"/>
                     <TextField promptText="Apellido" prefHeight="40" maxWidth="Infinity"/>
                     <Label text="Cédula de Ciudadanía *" style="-fx-font-weight: bold;"/>
                     <TextField promptText="Cédula de Ciudadanía" prefHeight="40" maxWidth="Infinity"/>
                     <Label text="Celular (opcional)" style="-fx-font-weight: bold;"/>
                     <TextField promptText="Celular" prefHeight="40" maxWidth="Infinity"/>
                     <Label text="Correo Electrónico (opcional)" style="-fx-font-weight: bold;"/>
                     <TextField promptText="Correo" prefHeight="40" maxWidth="Infinity"/>
                     <Label text="Género *" style="-fx-font-weight: bold;"/>
                     <ChoiceBox maxWidth="Infinity" prefHeight="40" styleClass="combo-box"/>
                     <Label text="Fecha de Nacimiento *" style="-fx-font-weight: bold;"/>
                     <DatePicker maxWidth="Infinity" prefHeight="40" styleClass="date-picker"/>
                  </VBox>
               </content>
            </ScrollPane>
            <Button fx:id="btnLogin11"
                    onAction="#onBtnIniciarSesionClicked"
                    text="Crear cuenta" maxWidth="Infinity" prefHeight="44"
                    style="-fx-font-size: 14px;"/>
         </children>
      </VBox>

      <!-- ===== POPUP: OLVIDÓ CONTRASEÑA ===== -->
      <VBox fx:id="popupOlvidoContrasena"
            styleClass="ventana-popup"
            maxWidth="420"
            visible="false"
            style="-fx-padding: 24;">
         <children>
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 16 0;">
               <Label styleClass="titulo-popup" text="¿Olvidó su contraseña?"
                      HBox.hgrow="ALWAYS"
                      style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
               <Button fx:id="btnLogin11"
                       onAction="#onBtnIniciarSesionClicked"
                       styleClass="btn-cerrar" text="✕"/>
            </HBox>
            <VBox spacing="10" style="-fx-padding: 0 0 20 0;">
               <Label text="Nombre de usuario" style="-fx-font-weight: bold;"/>
               <TextField promptText="Escribe aquí" prefHeight="42" maxWidth="Infinity"/>
               <Label text="¿Cuál es el nombre de tu mejor amigo?" style="-fx-font-weight: bold;"/>
               <TextField promptText="Escribe aquí" prefHeight="42" maxWidth="Infinity"/>
            </VBox>
            <Button fx:id="btnLogin111"
                    onAction="#onBtnIniciarSesionClicked"
                    text="Enviar" maxWidth="Infinity" prefHeight="44"
                    style="-fx-font-size: 14px;"/>
         </children>
      </VBox>

   </children>
</StackPane>
