<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.proyecto.presentacion.controladores.ControladorAdmin"
           stylesheets="@../Estilos/estilos.css">
   <children>

      <!-- ===== PANEL PRINCIPAL ===== -->
      <VBox fx:id="panelPrincipal" spacing="14" maxWidth="Infinity" maxHeight="Infinity" style="-fx-padding: 14;">

         <StackPane styleClass="main-login-card" minHeight="80" maxWidth="Infinity" style="-fx-padding: 12 20 12 20;">
            <Label styleClass="info-title" text="Hola Admin" style="-fx-font-size: 26px;" StackPane.alignment="CENTER"/>
            <ImageView fitHeight="60" fitWidth="140" pickOnBounds="true" preserveRatio="true" StackPane.alignment="CENTER_LEFT">
               <image><Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png" /></image>
            </ImageView>
            <Button styleClass="button-logout" text="- Cerrar Sesión" onAction="#onCerrarSesion"
                    prefHeight="46" prefWidth="170" StackPane.alignment="CENTER_RIGHT"/>
         </StackPane>

         <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <content>
               <VBox spacing="14" style="-fx-padding: 4 0 4 0;">

                  <VBox styleClass="main-login-card" style="-fx-padding: 20;">
                     <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label styleClass="info-title" text="Turnos" HBox.hgrow="ALWAYS" style="-fx-font-size: 20px;"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button prefHeight="52" prefWidth="210" text="Gestionar Turnos" onAction="#onAbrirTurnos"/>
                     </HBox>
                  </VBox>

                  <VBox styleClass="main-login-card" style="-fx-padding: 20;">
                     <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label styleClass="info-title" text="Persona" HBox.hgrow="ALWAYS" style="-fx-font-size: 20px;"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button prefHeight="52" prefWidth="210" text="Crear/Editar Persona" onAction="#onAbrirPersonas"/>
                     </HBox>
                  </VBox>

                  <VBox styleClass="main-login-card" style="-fx-padding: 20;">
                     <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label styleClass="info-title" text="Usuario" HBox.hgrow="ALWAYS" style="-fx-font-size: 20px;"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button prefHeight="52" prefWidth="210" text="Crear/Editar Usuario" onAction="#onAbrirUsuarios"/>
                     </HBox>
                  </VBox>

                  <Label styleClass="info-title" text="Asignar Rol (Agendador, Medico, Paciente)" style="-fx-font-size: 18px;"/>
                  <VBox styleClass="main-login-card" style="-fx-padding: 20;">
                     <HBox alignment="CENTER_LEFT" spacing="16">
                        <ComboBox fx:id="cbPersonaRol" prefHeight="52" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  promptText="Persona" style="-fx-font-size: 15px;" styleClass="combo-box"/>
                        <ComboBox fx:id="cbRol" prefHeight="52" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  promptText="Rol" style="-fx-font-size: 15px;" styleClass="combo-box"/>
                        <Button prefHeight="52" prefWidth="190" text="Asignar Rol" onAction="#onAsignarRol"/>
                     </HBox>
                  </VBox>

                  <Label styleClass="info-title" text="Asignar Especialidad" style="-fx-font-size: 18px;"/>
                  <VBox styleClass="main-login-card" style="-fx-padding: 20;">
                     <HBox alignment="CENTER_LEFT" spacing="16">
                        <ComboBox fx:id="cbMedicoEspecialidad" prefHeight="52" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  promptText="Medico" style="-fx-font-size: 15px;" styleClass="combo-box"/>
                        <ComboBox fx:id="cbEspecialidad" prefHeight="52" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  promptText="Especialidad" style="-fx-font-size: 15px;" styleClass="combo-box"/>
                        <Button prefHeight="52" prefWidth="220" text="Asignar Especialidad" onAction="#onAsignarEspecialidad"/>
                     </HBox>
                  </VBox>

               </VBox>
            </content>
         </ScrollPane>
      </VBox>


      <!-- ===== PANEL TURNOS ===== -->
      <VBox fx:id="panelTurnos" maxWidth="Infinity" maxHeight="Infinity" visible="false">

         <StackPane styleClass="main-login-card" minHeight="80" maxWidth="Infinity" style="-fx-padding: 12 20 12 20;">
            <Label styleClass="info-title" text="Gestión de Turnos" style="-fx-font-size: 26px;" StackPane.alignment="CENTER"/>
            <ImageView fitHeight="60" fitWidth="140" pickOnBounds="true" preserveRatio="true" StackPane.alignment="CENTER_LEFT">
               <image><Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png" /></image>
            </ImageView>
            <Button styleClass="button-logout" text="← Volver" onAction="#onVolverDesdePanel"
                    prefHeight="46" prefWidth="140" StackPane.alignment="CENTER_RIGHT"/>
         </StackPane>

         <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
               <VBox spacing="14" style="-fx-padding: 14;">

                  <Label styleClass="info-title" text="Lista de Turnos" style="-fx-font-size: 20px;"/>

                  <VBox styleClass="main-login-card" maxWidth="Infinity" style="-fx-padding: 8;">
                     <TableView fx:id="tblTurnos" prefHeight="220" maxWidth="Infinity">
                        <columns>
                           <TableColumn fx:id="colTurnoCedMedico"  prefWidth="150" text="Cédula Médico"/>
                           <TableColumn fx:id="colTurnoNomMedico"  prefWidth="210" text="Nombre Médico"/>
                           <TableColumn fx:id="colTurnoFecha"      prefWidth="150" text="Fecha del Turno"/>
                           <TableColumn fx:id="colTurnoHoraInicio" prefWidth="110" text="Hora Inicio"/>
                           <TableColumn fx:id="colTurnoHoraFin"    prefWidth="110" text="Hora Final"/>
                           <TableColumn fx:id="colTurnoEstado"     prefWidth="110" text="Estado"/>
                        </columns>
                     </TableView>
                  </VBox>

                  <Label styleClass="info-title" text="Información del Turno" style="-fx-font-size: 20px;"/>

                  <VBox styleClass="main-login-card" maxWidth="Infinity" style="-fx-padding: 20;">
                     <GridPane hgap="20" vgap="14" maxWidth="Infinity">
                        <columnConstraints>
                           <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                           <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Doctor *" style="-fx-font-size: 15px; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="cbTurnoDoctor" prefHeight="48" maxWidth="Infinity"
                                  promptText="Seleccione un Doctor" styleClass="combo-box"
                                  style="-fx-font-size: 14px;" onAction="#onSeleccionarDoctor"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2"/>

                        <Label text="Cédula del Médico" style="-fx-font-size: 15px; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label text="Nombre del Médico" style="-fx-font-size: 15px; -fx-font-weight: bold;"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtTurnoCedMedico" prefHeight="48" maxWidth="Infinity"
                                   promptText="Se completa al seleccionar doctor" editable="false"
                                   style="-fx-background-color: #f0f0f0; -fx-font-size: 14px;"
                                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtTurnoNomMedico" prefHeight="48" maxWidth="Infinity"
                                   promptText="Se completa al seleccionar doctor" editable="false"
                                   style="-fx-background-color: #f0f0f0; -fx-font-size: 14px;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Fecha del Turno *" style="-fx-font-size: 15px; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <Label text="Hora Inicio *" style="-fx-font-size: 15px; -fx-font-weight: bold;"
                               GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        <DatePicker fx:id="dpTurnoFecha" prefHeight="48" maxWidth="Infinity" styleClass="date-picker"
                                    GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <ComboBox fx:id="cbTurnoHoraInicio" prefHeight="48" maxWidth="Infinity"
                                  promptText="Hora inicio" style="-fx-font-size: 14px;"
                                  GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                        <Label text="Hora Final *" style="-fx-font-size: 15px; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                        <Label text="Estado del Turno" style="-fx-font-size: 15px; -fx-font-weight: bold;"
                               GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                        <ComboBox fx:id="cbTurnoHoraFin" prefHeight="48" maxWidth="Infinity"
                                  promptText="Hora final" style="-fx-font-size: 14px;"
                                  GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                        <CheckBox fx:id="chkTurnoActivo" prefHeight="48" maxWidth="Infinity"
                                  text="Turno Activo" style="-fx-font-size: 15px;"
                                  GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                     </GridPane>
                  </VBox>

                  <HBox spacing="14" alignment="CENTER_RIGHT">
                     <Button prefHeight="50" prefWidth="170" styleClass="btn-amarillo-vivo" text="Editar Turno" onAction="#onEditarTurno"/>
                     <Button prefHeight="50" prefWidth="160" text="Crear Turno" onAction="#onCrearTurno"/>
                     <Button prefHeight="50" prefWidth="175" styleClass="button-logout" text="Eliminar Turno" onAction="#onEliminarTurno"/>
                  </HBox>

               </VBox>
            </content>
         </ScrollPane>
      </VBox>


      <!-- ===== PANEL PERSONAS ===== -->
      <VBox fx:id="panelPersonas" maxWidth="Infinity" maxHeight="Infinity" visible="false">

         <StackPane styleClass="main-login-card" minHeight="80" maxWidth="Infinity" style="-fx-padding: 12 20 12 20;">
            <Label styleClass="info-title" text="Gestión de Personas" style="-fx-font-size: 26px;" StackPane.alignment="CENTER"/>
            <ImageView fitHeight="60" fitWidth="140" pickOnBounds="true" preserveRatio="true" StackPane.alignment="CENTER_LEFT">
               <image><Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png" /></image>
            </ImageView>
            <Button styleClass="button-logout" text="← Volver" onAction="#onVolverDesdePanel"
                    prefHeight="46" prefWidth="140" StackPane.alignment="CENTER_RIGHT"/>
         </StackPane>

         <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
               <VBox spacing="14" style="-fx-padding: 14;">

                  <Label styleClass="info-title" text="Lista de Personas" style="-fx-font-size: 20px;"/>

                  <VBox styleClass="main-login-card" maxWidth="Infinity" style="-fx-padding: 8;">
                     <TableView fx:id="tblPersonas" prefHeight="220" maxWidth="Infinity">
                        <columns>
                           <TableColumn fx:id="colPerCedula"   prefWidth="180" text="Cédula de Ciudadanía"/>
                           <TableColumn fx:id="colPerNombre"   prefWidth="140" text="Nombre"/>
                           <TableColumn fx:id="colPerApellido" prefWidth="140" text="Apellido"/>
                           <TableColumn fx:id="colPerCelular"  prefWidth="120" text="Celular"/>
                           <TableColumn fx:id="colPerFechaNac" prefWidth="160" text="Fecha de Nacimiento"/>
                           <TableColumn fx:id="colPerCorreo"   prefWidth="180" text="Correo Electrónico"/>
                           <TableColumn fx:id="colPerGenero"   prefWidth="100" text="Género"/>
                        </columns>
                     </TableView>
                  </VBox>

                  <Label styleClass="info-title" text="Información Persona" style="-fx-font-size: 20px;"/>

                  <VBox styleClass="main-login-card" maxWidth="Infinity" style="-fx-padding: 20;">
                     <GridPane hgap="20" vgap="14" maxWidth="Infinity">
                        <columnConstraints>
                           <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                           <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Cédula de Ciudadanía *" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtPerCedula"   prefHeight="48" maxWidth="Infinity" promptText="Cédula de Ciudadanía" style="-fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label text="Nombre *" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtPerNombre"   prefHeight="48" maxWidth="Infinity" promptText="Nombre" style="-fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="Apellido *" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtPerApellido" prefHeight="48" maxWidth="Infinity" promptText="Apellido" style="-fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <Label text="Celular (Opcional)" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtPerCelular"  prefHeight="48" maxWidth="Infinity" promptText="Celular" style="-fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <Label text="Fecha de Nacimiento *" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <DatePicker fx:id="dpPerFechaNac" prefHeight="48" maxWidth="Infinity" styleClass="date-picker" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <Label text="Correo Electrónico (Opcional)" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtPerCorreo"   prefHeight="48" maxWidth="Infinity" promptText="Correo Electrónico" style="-fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                        <Label text="Género *" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                        <ChoiceBox fx:id="cbPerGenero"    prefHeight="48" maxWidth="Infinity" styleClass="combo-box" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                     </GridPane>
                  </VBox>

                  <HBox spacing="14" alignment="CENTER_RIGHT">
                     <Button prefHeight="50" prefWidth="170" styleClass="btn-amarillo-vivo" text="Editar Persona" onAction="#onEditarPersona"/>
                     <Button prefHeight="50" prefWidth="160" text="Crear Persona" onAction="#onCrearPersona"/>
                     <Button prefHeight="50" prefWidth="175" styleClass="button-logout" text="Eliminar Persona" onAction="#onEliminarPersona"/>
                  </HBox>

               </VBox>
            </content>
         </ScrollPane>
      </VBox>


      <!-- ===== PANEL USUARIOS ===== -->
      <VBox fx:id="panelUsuarios" maxWidth="Infinity" maxHeight="Infinity" visible="false">

         <StackPane styleClass="main-login-card" minHeight="80" maxWidth="Infinity" style="-fx-padding: 12 20 12 20;">
            <Label styleClass="info-title" text="Gestión de Usuarios" style="-fx-font-size: 26px;" StackPane.alignment="CENTER"/>
            <ImageView fitHeight="60" fitWidth="140" pickOnBounds="true" preserveRatio="true" StackPane.alignment="CENTER_LEFT">
               <image><Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png" /></image>
            </ImageView>
            <Button styleClass="button-logout" text="← Volver" onAction="#onVolverDesdePanel"
                    prefHeight="46" prefWidth="140" StackPane.alignment="CENTER_RIGHT"/>
         </StackPane>

         <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
               <VBox spacing="14" style="-fx-padding: 14;">

                  <Label styleClass="info-title" text="Lista de Usuarios" style="-fx-font-size: 20px;"/>

                  <VBox styleClass="main-login-card" maxWidth="Infinity" style="-fx-padding: 8;">
                     <TableView fx:id="tblUsuarios" prefHeight="220" maxWidth="Infinity">
                        <columns>
                           <TableColumn fx:id="colUsuNombre"     prefWidth="380" text="Nombre de Usuario"/>
                           <TableColumn fx:id="colUsuContrasena" prefWidth="360" text="Contraseña"/>
                        </columns>
                     </TableView>
                  </VBox>

                  <Label styleClass="info-title" text="Información Usuario" style="-fx-font-size: 20px;"/>

                  <VBox styleClass="main-login-card" maxWidth="Infinity" style="-fx-padding: 20;">
                     <GridPane hgap="20" vgap="14" maxWidth="Infinity">
                        <columnConstraints>
                           <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                           <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Usuario *" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtUsuNombre"     prefHeight="48" maxWidth="Infinity" promptText="Nombre de Usuario" style="-fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label text="Contraseña *" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtUsuContrasena" prefHeight="48" maxWidth="Infinity" promptText="Contraseña" style="-fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                     </GridPane>
                  </VBox>

                  <HBox spacing="14" alignment="CENTER_RIGHT">
                     <Button prefHeight="50" prefWidth="170" styleClass="btn-amarillo-vivo" text="Editar Usuario" onAction="#onEditarUsuario"/>
                     <Button prefHeight="50" prefWidth="160" text="Crear Usuario" onAction="#onCrearUsuario"/>
                     <Button prefHeight="50" prefWidth="175" styleClass="button-logout" text="Eliminar Usuario" onAction="#onEliminarUsuario"/>
                  </HBox>

               </VBox>
            </content>
         </ScrollPane>
      </VBox>

   </children>
</StackPane>
