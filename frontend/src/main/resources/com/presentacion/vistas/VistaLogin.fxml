<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.proyecto.presentacion.controladores.ControladorLogin"
           stylesheets="@../Estilos/estilos.css">
   <children>

      <!-- ===== PANTALLA PRINCIPAL LOGIN ===== -->
      <HBox fx:id="panelLogin" maxWidth="Infinity" maxHeight="Infinity">

         <!-- Panel izquierdo: formulario -->
         <VBox alignment="CENTER"
               spacing="0"
               styleClass="logo-card"
               HBox.hgrow="ALWAYS"
               maxWidth="Infinity"
               style="-fx-padding: 50 50 40 50;">
            <children>
               <Label styleClass="info-title" text="Bienvenido" />
               <Label styleClass="label-grey-small"
                      text="Por favor ingrese sus credenciales para acceder al portal de pacientes."
                      wrapText="true"
                      style="-fx-padding: 0 0 30 0;"/>

               <Label text="Usuario" style="-fx-padding: 10 0 4 0;"/>
               <TextField fx:id="txtUsuario"
                          prefHeight="42.0"
                          maxWidth="Infinity"
                          promptText="Usuario123"
                          styleClass="text-field"/>
               <Label fx:id="lblErrorUsuario"
                      maxWidth="Infinity"
                      style="-fx-text-fill: red; -fx-font-size: 11px; -fx-padding: 2 0 0 0;"/>

               <Label text="Contraseña" style="-fx-padding: 10 0 4 0;"/>
               <PasswordField fx:id="txtContrasena"
                              prefHeight="42.0"
                              maxWidth="Infinity"
                              promptText="****"
                              styleClass="password-field"/>

               <Hyperlink text="¿Olvidó su contraseña?"
                          style="-fx-padding: 8 0 20 0; -fx-alignment: center-right;"/>

               <Button fx:id="btnLogin"
                       onAction="#onBtnIniciarSesionClicked"
                       prefHeight="42.0"
                       maxWidth="Infinity"
                       text="INICIAR SESIÓN"/>

               <HBox alignment="CENTER" spacing="4" style="-fx-padding: 20 0 0 0;">
                  <Label styleClass="label-grey-small" text="¿No tienes una cuenta?" />
                  <Hyperlink text="Regístrese aquí" />
               </HBox>
            </children>
         </VBox>

         <!-- Panel derecho: info + logo -->
         <VBox alignment="CENTER"
               spacing="20"
               styleClass="login-right-pane"
               HBox.hgrow="ALWAYS"
               maxWidth="Infinity"
               style="-fx-padding: 40;">
            <children>
               <VBox styleClass="logo-card" alignment="CENTER" style="-fx-padding: 20;">
                  <ImageView fitHeight="108.0" fitWidth="249.0"
                             pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png" />
                     </image>
                  </ImageView>
               </VBox>
               <Label styleClass="info-title"
                      text="Salud y Bienestar a su Alcance"
                      wrapText="true"
                      maxWidth="Infinity"/>
               <Label styleClass="info-text"
                      text="Gestione sus citas médicas de manera rápida y segura. Accede a su historial, reserve especialistas y mantenga el control de su salud."
                      textAlignment="JUSTIFY"
                      wrapText="true"
                      maxWidth="Infinity"/>
            </children>
         </VBox>
      </HBox>

      <!-- ===== POPUP: CREAR CUENTA ===== -->
      <VBox fx:id="popupCrearCuenta"
            styleClass="ventana-popup"
            maxWidth="420"
            maxHeight="600"
            visible="false"
            style="-fx-padding: 20;">
         <children>
            <HBox alignment="CENTER_LEFT">
               <Label styleClass="titulo-popup" text="Crear Cuenta" HBox.hgrow="ALWAYS"/>
               <Button fx:id="btnLogin1"
                       onAction="#onBtnIniciarSesionClicked"
                       styleClass="btn-cerrar"
                       text="X"/>
            </HBox>
            <ScrollPane fitToWidth="true" prefHeight="480" style="-fx-padding: 10 0 0 0;">
               <content>
                  <VBox spacing="8" style="-fx-padding: 5;">
                     <Label text="Nombre de Usuario *"/>
                     <TextField promptText="Nombre de usuario"/>
                     <Label text="Contraseña *"/>
                     <TextField promptText="Contraseña"/>
                     <Label text="Nombre *"/>
                     <TextField promptText="Nombre"/>
                     <Label text="Apellido *"/>
                     <TextField promptText="Apellido"/>
                     <Label text="Cédula de Ciudadanía *"/>
                     <TextField promptText="Cédula de Ciudadanía"/>
                     <Label text="Celular (opcional)"/>
                     <TextField promptText="Celular"/>
                     <Label text="Correo Electrónico (opcional)"/>
                     <TextField promptText="Correo"/>
                     <Label text="Género *"/>
                     <ChoiceBox maxWidth="Infinity" styleClass="combo-box"/>
                     <Label text="Fecha de Nacimiento *"/>
                     <DatePicker maxWidth="Infinity" styleClass="date-picker"/>
                  </VBox>
               </content>
            </ScrollPane>
            <Button fx:id="btnLogin11"
                    onAction="#onBtnIniciarSesionClicked"
                    text="Crear cuenta"
                    maxWidth="Infinity"
                    prefHeight="42"
                    style="-fx-margin: 10 0 0 0;"/>
         </children>
      </VBox>

      <!-- ===== POPUP: OLVIDÓ CONTRASEÑA ===== -->
      <VBox fx:id="popupOlvidoContrasena"
            styleClass="ventana-popup"
            maxWidth="420"
            visible="false"
            style="-fx-padding: 20;">
         <children>
            <HBox alignment="CENTER_LEFT">
               <Label styleClass="titulo-popup" text="¿Olvidó su contraseña?" HBox.hgrow="ALWAYS"/>
               <Button fx:id="btnLogin11"
                       onAction="#onBtnIniciarSesionClicked"
                       styleClass="btn-cerrar"
                       text="X"/>
            </HBox>
            <VBox spacing="8" style="-fx-padding: 20 0 20 0;">
               <Label text="Escribe tu nombre de usuario"/>
               <TextField promptText="Escribe aquí"/>
               <Label text="¿Cuál es el nombre de tu mejor amigo?"/>
               <TextField promptText="Escribe aquí"/>
            </VBox>
            <Button fx:id="btnLogin111"
                    onAction="#onBtnIniciarSesionClicked"
                    text="Enviar"
                    maxWidth="Infinity"
                    prefHeight="42"/>
         </children>
      </VBox>

   </children>
</StackPane>
