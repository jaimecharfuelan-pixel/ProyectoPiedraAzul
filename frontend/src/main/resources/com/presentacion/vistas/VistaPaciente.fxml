<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.proyecto.presentacion.controladores.ControladorPaciente"
           stylesheets="@../Estilos/estilos.css">
   <children>
      <VBox spacing="16"
            maxWidth="Infinity"
            maxHeight="Infinity"
            style="-fx-padding: 14;">

         <!-- HEADER -->
         <HBox styleClass="main-login-card"
               alignment="CENTER_LEFT"
               spacing="16"
               style="-fx-padding: 10 16 10 16;"
               minHeight="64"
               maxWidth="Infinity">
            <ImageView fitHeight="50.0" fitWidth="100.0"
                       pickOnBounds="true" preserveRatio="true">
               <image><Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png" /></image>
            </ImageView>
            <Label styleClass="info-title" text="Hola Paciente" HBox.hgrow="ALWAYS"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false"
                    text="+ Agendar Cita"
                    onAction="#onAgendarCita"/>
            <Button mnemonicParsing="false"
                    styleClass="button-logout"
                    text="- Cerrar Sesión"
                    onAction="#onCerrarSesion"/>
         </HBox>

         <!-- HISTORIAL -->
         <Label styleClass="info-title" text="Historial Cita"/>
         <VBox styleClass="main-login-card"
               VBox.vgrow="ALWAYS"
               maxWidth="Infinity"
               style="-fx-padding: 8;">
            <TableView fx:id="tblHistorial"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity"
                       maxHeight="Infinity">
               <columns>
                  <TableColumn fx:id="colHistNomPaciente" prefWidth="160" text="Nombre Paciente"/>
                  <TableColumn fx:id="colHistCedMedico"   prefWidth="140" text="Cédula Medico"/>
                  <TableColumn fx:id="colHistNomMedico"   prefWidth="200" text="Nombre Medico"/>
                  <TableColumn fx:id="colHistFecha"       prefWidth="150" text="Fecha del Turno"/>
                  <TableColumn fx:id="colHistHoraInicio"  prefWidth="100" text="Hora Inicio"/>
                  <TableColumn fx:id="colHistHoraFin"     prefWidth="100" text="Hora Final"/>
                  <TableColumn fx:id="colHistEstado"      prefWidth="140" text="Estado de la Cita"/>
               </columns>
            </TableView>
         </VBox>

         <!-- CITAS FUTURAS -->
         <Label styleClass="info-title" text="Citas Futuras"/>
         <VBox styleClass="main-login-card"
               VBox.vgrow="ALWAYS"
               maxWidth="Infinity"
               style="-fx-padding: 8;">
            <TableView fx:id="tblFuturas"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity"
                       maxHeight="Infinity">
               <columns>
                  <TableColumn fx:id="colFutNomPaciente" prefWidth="160" text="Nombre Paciente"/>
                  <TableColumn fx:id="colFutCedMedico"   prefWidth="140" text="Cédula Medico"/>
                  <TableColumn fx:id="colFutNomMedico"   prefWidth="200" text="Nombre Medico"/>
                  <TableColumn fx:id="colFutFecha"       prefWidth="150" text="Fecha del Turno"/>
                  <TableColumn fx:id="colFutHoraInicio"  prefWidth="100" text="Hora Inicio"/>
                  <TableColumn fx:id="colFutHoraFin"     prefWidth="100" text="Hora Final"/>
                  <TableColumn fx:id="colFutEstado"      prefWidth="140" text="Estado de la Cita"/>
               </columns>
            </TableView>
         </VBox>

      </VBox>
   </children>
</StackPane>
