<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.proyecto.presentacion.controladores.ControladorAgendador"
           stylesheets="@../Estilos/estilos.css">

    <children>
        <!-- Contenedor principal con padding para separar del borde -->
        <VBox spacing="20"
              alignment="TOP_CENTER"
              maxWidth="Infinity"
              prefWidth="Infinity"
              style="-fx-padding: 20;"
              StackPane.alignment="CENTER">

            <!-- Header con logo más grande -->
            <HBox spacing="20"
                  alignment="CENTER_RIGHT"
                  styleClass="main-login-card"
                  prefHeight="90"
                  maxWidth="Infinity"
                  prefWidth="Infinity">

                <children>
                    <ImageView fitHeight="70"
                               fitWidth="160"
                               preserveRatio="true">
                        <image>
                            <Image url="@/com/presentacion/icons/LOGO_PIEDRA_AZUL.png"/>
                        </image>
                    </ImageView>

                    <Pane HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nueva Cita"
                            prefWidth="160"
                            prefHeight="48"
                            style="-fx-font-size: 16px;"
                            onAction="#onNuevaCita"/>

                    <Button text="- Cerrar Sesión"
                            prefWidth="160"
                            prefHeight="48"
                            styleClass="button-logout"
                            style="-fx-font-size: 16px;"
                            onAction="#onCerrarSesion"/>
                </children>
            </HBox>

            <!-- Título con tamaño aumentado -->
            <Label text="Panel Principal"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

            <!-- Tarjetas con imágenes arriba y texto abajo -->
            <HBox spacing="20"
                  alignment="CENTER"
                  maxWidth="Infinity"
                  prefWidth="Infinity">

                <!-- Tarjeta 1: Citas para hoy -->
                <VBox styleClass="main-login-card"
                      HBox.hgrow="ALWAYS"
                      prefHeight="160"
                      alignment="CENTER"
                      spacing="10">
                    <children>
                        <ImageView fitHeight="56" fitWidth="56" preserveRatio="true">
                             <image>
                                <Image url="@/com/presentacion/icons/calendario.png"/>
                            </image>
                        </ImageView>
                        <Label text="CITAS PARA HOY"
                               style="-fx-font-size: 16px; -fx-font-weight: normal;"/>
                        <Label fx:id="lblTotalHoy"
                               text="5"
                               style="-fx-font-size: 40px; -fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <!-- Tarjeta 2: Pendientes de confirmación -->
                <VBox styleClass="main-login-card"
                      HBox.hgrow="ALWAYS"
                      prefHeight="160"
                      alignment="CENTER"
                      spacing="10">
                    <children>
                        <ImageView fitHeight="56" fitWidth="56" preserveRatio="true">
                             <image>
                                <Image url="@/com/presentacion/icons/Pendiente.png"/>
                            </image>
                        </ImageView>
                        <Label text="PENDIENTES DE CONFIRMACIÓN"
                               style="-fx-font-size: 16px; -fx-font-weight: normal;"/>
                        <Label fx:id="lblPendientesConfirmacionHoy"
                               text="4"
                               style="-fx-font-size: 40px; -fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <!-- Tarjeta 3: Médicos activos -->
                <VBox styleClass="main-login-card"
                      HBox.hgrow="ALWAYS"
                      prefHeight="160"
                      alignment="CENTER"
                      spacing="10">
                    <children>
                        <ImageView fitHeight="56" fitWidth="56" preserveRatio="true">
                             <image>
                                <Image url="@/com/presentacion/icons/botiquin-medico.png"/>
                            </image>
                        </ImageView>
                        <Label text="MÉDICOS ACTIVOS"
                               style="-fx-font-size: 16px; -fx-font-weight: normal;"/>
                        <Label fx:id="medicosActivos"
                               text="12"
                               style="-fx-font-size: 40px; -fx-font-weight: bold;"/>
                    </children>
                </VBox>
            </HBox>

            <!-- Título lista con tamaño aumentado -->
            <Label text="Lista Citas"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

            <!-- Filtros -->
            <HBox spacing="20"
                  alignment="CENTER_LEFT"
                  maxWidth="Infinity"
                  prefWidth="Infinity">

                <children>
                    <DatePicker fx:id="dpFechaFiltro"
                                prefHeight="44"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>

                    <ComboBox fx:id="cbDoctorFiltro"
                              prefHeight="44"
                              promptText="Seleccione un Doctor"
                              HBox.hgrow="ALWAYS"
                              maxWidth="Infinity"/>

                    <Button text="Filtrar"
                            prefWidth="130"
                            prefHeight="44"
                            style="-fx-font-size: 14px;"
                            onAction="#onFiltrar"/>
                </children>
            </HBox>

            <!-- Tabla con redimensionamiento automático (CORREGIDO) -->
            <VBox styleClass="main-login-card"
                  maxWidth="Infinity"
                  prefWidth="Infinity"
                  VBox.vgrow="ALWAYS"
                  alignment="CENTER">

                <children>
                    <TableView fx:id="tblCitas"
                               VBox.vgrow="ALWAYS"
                               maxWidth="Infinity"
                               prefWidth="Infinity">

                        <columns>
                            <TableColumn fx:id="colPaciente"
                                         text="Paciente"
                                         prefWidth="200"
                                         style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

                            <TableColumn fx:id="colHora"
                                         text="Hora"
                                         prefWidth="100"
                                         style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

                            <TableColumn fx:id="colFecha"
                                         text="Fecha"
                                         prefWidth="150"
                                         style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

                            <TableColumn fx:id="colMedico"
                                         text="Medico"
                                         prefWidth="250"
                                         style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                        </columns>
                    </TableView>
                </children>
            </VBox>

        </VBox>
    </children>
</StackPane>