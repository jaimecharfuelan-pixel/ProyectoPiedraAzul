<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="800.0"
            stylesheets="@../Estilos/estilos.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proyecto.presentacion.controladores.ControladorAgendarCita">

   <children>

      <!-- HEADER -->
      <VBox layoutX="11.0" layoutY="14.0" prefHeight="64.0" prefWidth="778.0" styleClass="main-login-card">
         <children>
            <Pane prefHeight="78.0" prefWidth="778.0">
               <children>
                  <ImageView fitHeight="57.0" fitWidth="109.0" layoutX="323.0" preserveRatio="true">
                     <image>
                        <Image url="@../../../icons/LOGO%20PIEDRA%20AZUL.png" />
                     </image>
                  </ImageView>
               </children>
            </Pane>
         </children>
      </VBox>

      <!-- FORM -->
      <VBox layoutX="89.0" layoutY="88.0" prefHeight="492.0" prefWidth="595.0" styleClass="main-login-card">
         <children>
            <Pane prefHeight="494.0" prefWidth="596.0">

               <!-- BOTONES -->
               <Button fx:id="btnGuardar"
                       layoutX="445.0" layoutY="452.0"
                       onAction="#onGuardarCita"
                       prefWidth="130.0"
                       text="+ Guardar Cita"/>

               <Button layoutX="307.0" layoutY="452.0"
                       prefWidth="130.0"
                       text="- Cancelar"/>

               <Label layoutX="14.0" styleClass="info-title" text="Agendar Cita" />

               <!-- SCROLL -->
               <ScrollPane layoutY="59.0" prefHeight="385.0" prefWidth="589.0">
                  <content>
                     <AnchorPane>

                        <GridPane styleClass="scroll-blanco">

                           <!-- NOMBRE -->
                           <Pane>
                              <children>
                                 <TextField fx:id="txtNombre"
                                            layoutX="6.0" layoutY="35.0"
                                            prefWidth="268.0"
                                            promptText="Nombre"/>
                                 <Label layoutX="16.0" layoutY="14.0" text="Nombre *"/>
                              </children>
                           </Pane>

                           <!-- APELLIDO -->
                           <Pane GridPane.columnIndex="1">
                              <children>
                                 <TextField fx:id="txtApellido"
                                            layoutX="11.0" layoutY="33.0"
                                            prefWidth="268.0"
                                            promptText="Apellido"/>
                                 <Label layoutX="16.0" layoutY="11.0" text="Apellido *"/>
                              </children>
                           </Pane>

                           <!-- CEDULA -->
                           <Pane GridPane.rowIndex="1">
                              <children>
                                 <TextField fx:id="txtCedula"
                                            layoutX="7.0" layoutY="39.0"
                                            prefWidth="268.0"
                                            promptText="Cédula"/>
                                 <Label layoutX="16.0" layoutY="17.0" text="Cédula *"/>
                              </children>
                           </Pane>

                           <!-- CORREO -->
                           <Pane GridPane.columnIndex="1" GridPane.rowIndex="1">
                              <children>
                                 <TextField fx:id="txtCorreo"
                                            layoutX="8.0" layoutY="38.0"
                                            prefWidth="268.0"
                                            promptText="Correo"/>
                                 <Label layoutX="16.0" layoutY="16.0" text="Correo (Opcional)"/>
                              </children>
                           </Pane>

                           <!-- CELULAR -->
                           <Pane GridPane.rowIndex="2">
                              <children>
                                 <TextField fx:id="txtCelular"
                                            layoutX="9.0" layoutY="38.0"
                                            prefWidth="268.0"
                                            promptText="Celular"/>
                                 <Label layoutX="16.0" layoutY="16.0" text="Celular"/>
                              </children>
                           </Pane>

                           <!-- GENERO -->
                           <Pane GridPane.columnIndex="1" GridPane.rowIndex="2">
                              <children>
                                 <ChoiceBox fx:id="cbGenero"
                                            layoutX="10.0" layoutY="39.0"
                                            prefWidth="265.0"/>
                                 <Label layoutX="16.0" layoutY="16.0" text="Género"/>
                              </children>
                           </Pane>

                           <!-- FECHA -->
                           <Pane GridPane.rowIndex="3">
                              <children>
                                 <DatePicker fx:id="dpFecha"
                                             layoutX="10.0" layoutY="33.0"
                                             prefWidth="269.0"/>
                                 <Label layoutX="16.0" layoutY="11.0" text="Fecha *"/>
                              </children>
                           </Pane>

                           <!-- HORA -->
                           <Pane GridPane.columnIndex="1" GridPane.rowIndex="3">
                              <children>
                                 <ComboBox fx:id="cbHora"
                                           layoutX="11.0" layoutY="33.0"
                                           prefWidth="264.0"/>
                                 <Label layoutX="16.0" layoutY="12.0" text="Hora *"/>
                              </children>
                           </Pane>

                           <!-- DOCTOR -->
                           <Pane GridPane.rowIndex="4">
                              <children>
                                 <ComboBox fx:id="cbMedico"
                                           layoutX="9.0" layoutY="36.0"
                                           prefWidth="272.0"
                                           promptText="Seleccione un Doctor"/>
                                 <Label layoutX="16.0" layoutY="14.0" text="Doctor *"/>
                              </children>
                           </Pane>

                           <!-- MOTIVO -->
                           <Pane GridPane.columnIndex="1" GridPane.rowIndex="4">
                              <children>
                                 <TextArea fx:id="txtMotivo"
                                           layoutX="11.0" layoutY="37.0"
                                           prefWidth="263.0"
                                           promptText="Motivo"/>
                                 <Label layoutX="21.0" layoutY="14.0" text="Motivo *"/>
                              </children>
                           </Pane>

                        </GridPane>
                     </AnchorPane>
                  </content>
               </ScrollPane>

            </Pane>
         </children>
      </VBox>

   </children>
</AnchorPane>
